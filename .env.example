# 🔍 Google Search Console site verification key configuration
# Can use the public-facing variable (recommended for client-side inclusion visibility)
PUBLIC_GOOGLE_SITE_VERIFICATION=your_gsc_verification_code_here
# Or private-facing variable (resolved server-side during compilation)
GOOGLE_SITE_VERIFICATION=your_gsc_verification_code_here

# 📊 Microsoft Clarity Project ID configuration
# Can use the public-facing variable (recommended)
PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id_here
# Or private-facing variable (resolved during compilation)
CLARITY_PROJECT_ID=your_clarity_project_id_here
