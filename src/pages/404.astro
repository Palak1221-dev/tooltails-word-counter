---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';

const seoTitle = "404 | Tooltails";
const seoDescription = "The page you're looking for doesn't exist or may have been moved.";
---

<Layout title={seoTitle} description={seoDescription} robots="noindex">
  <SiteHeader />
  
  <main class="min-h-[70vh] flex items-center justify-center bg-canvas-soft text-ink font-geist relative overflow-hidden px-4 sm:px-6 py-20">
    {/* Background Decorative Mesh */}
    <div class="absolute inset-0 mesh-gradient opacity-10 -z-10 h-[400px] pointer-events-none"></div>

    <div class="max-w-2xl w-full text-center flex flex-col items-center">
      
      {/* 404 Header Tag */}
      <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-[11px] font-geist-mono border border-hairline rounded-full bg-canvas/50 backdrop-blur-sm shadow-sm select-none">
        <span class="text-error font-extrabold">ERROR CODE</span>
        <div class="h-2 w-px bg-hairline"></div>
        <span class="text-body font-medium uppercase tracking-wider">404</span>
      </div>

      {/* Hero 404 Text */}
      <h1 class="text-7xl md:text-9xl font-black tracking-tighter text-ink mb-2 select-none leading-none">
        404
      </h1>
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-ink mb-4">
        Page Not Found
      </h2>
      <p class="text-base text-body max-w-md mb-2 leading-relaxed">
        The page you're looking for doesn't exist or may have been moved.
      </p>
      <p class="text-sm text-mute max-w-md mb-10 leading-relaxed">
        Lost? Start with the Word Counter or browse all Tooltails tools.
      </p>

      {/* Primary and Secondary CTA Buttons */}
      <div class="flex flex-col sm:flex-row items-center gap-4 mb-16 w-full sm:w-auto">
        <a 
          href="/word-counter/" 
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 h-12 text-sm font-bold rounded-full bg-primary text-on-primary hover:bg-primary/90 transition-all active:scale-[0.98] shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"
        >
          Back to Word Counter
        </a>
        <a 
          href="https://tooltails.com" 
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 h-12 text-sm font-bold rounded-full bg-canvas text-ink border border-hairline hover:bg-canvas-soft-2 transition-all active:scale-[0.98] shadow-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"
        >
          Explore All Tools
        </a>
      </div>

      {/* Helpful Links Section */}
      <div class="w-full border-t border-hairline pt-10">
        <h3 class="text-xs font-geist-mono text-mute uppercase tracking-[0.2em] mb-6">
          Popular Destinations
        </h3>
        <nav class="flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm font-medium text-body">
          <a href="/word-counter/" class="hover:text-primary transition-colors focus:outline-none">
            Word Counter
          </a>
          <a href="/word-counter/about" class="hover:text-primary transition-colors focus:outline-none">
            About
          </a>
          <a href="/word-counter/contact" class="hover:text-primary transition-colors focus:outline-none">
            Contact
          </a>
          <a href="/word-counter/privacy" class="hover:text-primary transition-colors focus:outline-none">
            Privacy Policy
          </a>
          <a href="/word-counter/terms" class="hover:text-primary transition-colors focus:outline-none">
            Terms of Service
          </a>
        </nav>
      </div>

    </div>
  </main>

  <SiteFooter />
</Layout>
