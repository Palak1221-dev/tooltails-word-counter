---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/layout/SiteHeader.astro';
import SiteFooter from '../../components/layout/SiteFooter.astro';

const seoTitle = "What Is a Good Readability Score? Flesch-Kincaid Guide";
const seoDescription = "What readability score should you aim for? Learn what makes a good Flesch Reading Ease score and how to interpret grade level metrics.";
const canonicalUrl = "https://tooltails.com/blog/what-is-good-readability-score/";

const faqs = [
  {
    question: "What is a good Flesch Reading Ease score?",
    answer: "A score between 60 and 70 is considered standard and is ideal for broad public audiences. This matches a 7th to 8th-grade reading level."
  },
  {
    question: "What does a Flesch-Kincaid grade level of 8 mean?",
    answer: "It means the text is written at a level that a typical US eighth-grader (around 13-14 years old) can easily comprehend. This is the recommended benchmark for professional web content."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tooltails.com" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://tooltails.com/blog/" },
      { "@type": "ListItem", "position": 3, "name": "Readability Scores", "item": "https://tooltails.com/blog/what-is-good-readability-score/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
    }))
  }
];
---

<Layout title={seoTitle} description={seoDescription} canonical={canonicalUrl}>
  <script type="application/ld+json" slot="head" is:inline set:html={JSON.stringify(schema)} />

  <SiteHeader />
  
  <main class="min-h-screen bg-canvas pt-8 pb-24">
    <article class="max-w-3xl mx-auto px-4 sm:px-6">
      <nav class="flex items-center gap-2 text-xs font-semibold text-mute uppercase tracking-wider mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span class="text-hairline-strong">/</span>
        <a href="/blog" class="hover:text-primary transition-colors">Blog</a>
        <span class="text-hairline-strong">/</span>
        <span class="text-ink">Linguistic Pace</span>
      </nav>

      <header class="mb-10 pb-8 border-b border-hairline">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-[9px] font-bold text-primary bg-primary/10 px-2.5 py-0.5 rounded-full uppercase tracking-wider">Analysis</span>
          <span class="text-xs text-mute font-medium">June 13, 2026</span>
          <span class="text-xs text-mute font-bold">•</span>
          <span class="text-xs text-mute font-bold uppercase tracking-widest">5 min read</span>
        </div>
        <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight text-ink mb-6 leading-tight">
          What Is a Good Readability Score?
        </h1>
        <p class="text-lg text-mute leading-relaxed">
          Understanding Flesch-Kincaid readability indices and how to score your writing for different audiences.
        </p>
      </header>

      <div class="space-y-8 text-body leading-relaxed text-base font-medium">
        <p>
          Readability metrics help authors ensure their writing matches the comprehension level of their intended audience. Let's look at what scores to target.
        </p>
        
        <h2 class="text-2xl font-bold tracking-tight text-ink mt-8">Flesch Reading Ease Benchmarks</h2>
        <ul class="list-disc pl-6 space-y-3">
          <li><strong>90-100 (Very Easy)</strong>: Easily understood by an average 11-year-old student (5th-grade level).</li>
          <li><strong>60-70 (Standard/Conversational)</strong>: Easily understood by 13- to 15-year-old students (8th to 9th-grade level). **Recommended for web copy**.</li>
          <li><strong>0-30 (Highly Complex)</strong>: Best understood by university graduates. Typical for academic papers and legal contracts.</li>
        </ul>

        {/* CTA */}
        <div class="my-10 bg-canvas-soft border border-hairline rounded-[2rem] p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6 shadow-sm">
          <div class="space-y-1.5 text-center md:text-left">
            <h4 class="text-sm font-bold text-ink">Test your readability instantly</h4>
            <p class="text-xs text-mute leading-relaxed max-w-sm">
              Type or paste your draft into the Tooltails Word Counter to compute Flesch-Kincaid grade levels in real time.
            </p>
          </div>
          <a href="/word-counter" class="inline-flex items-center justify-center px-6 h-10 text-xs font-bold text-on-primary bg-primary hover:bg-primary/95 rounded-full shadow-md active:scale-95 transition-all whitespace-nowrap">
            Analyze Readability Score
          </a>
        </div>
      </div>

      <section class="mt-20 pt-10 border-t border-hairline">
        <h3 class="text-xl font-bold tracking-tight text-ink mb-6">Frequently Asked Questions</h3>
        <div class="space-y-6">
          {faqs.map(faq => (
            <div class="space-y-2">
              <h4 class="font-bold text-ink text-sm">{faq.question}</h4>
              <p class="text-body text-sm leading-relaxed">{faq.answer}</p>
            </div>
          ))}
        </div>
      </section>
    </article>
  </main>

  <SiteFooter />
</Layout>
