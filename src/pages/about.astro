---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import FAQSection from '../components/layout/FAQSection.astro';

const seoTitle = "About Tooltails | Free Online Productivity Tools";
const seoDescription = "Learn about Tooltails, a collection of free online tools designed to help with everyday productivity, calculations, text analysis, and more.";
const canonicalUrl = "https://tooltails.com/about/";

const faqs = [
  {
    question: "What is Tooltails?",
    answer: "Tooltails is a growing collection of free, privacy-first online tools designed to help you with everyday productivity, text analysis, and calculations without the bloat."
  },
  {
    question: "Is Tooltails free?",
    answer: "Yes, Tooltails is completely free to use. There are no paywalls, hidden fees, or premium subscriptions required to access our tools."
  },
  {
    question: "Do I need an account?",
    answer: "No sign-up or registration is required. You can start using any of our tools immediately upon visiting the site."
  },
  {
    question: "Is my data stored?",
    answer: "No. We prioritize your privacy by processing your data locally in your browser whenever possible. We do not store your personal text or calculations on our servers."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout title={seoTitle} description={seoDescription} canonical={canonicalUrl}>
  <SiteHeader />
  
  <main class="min-h-screen pt-16 pb-24 bg-canvas">
    <article class="px-4 sm:px-6">
      <div class="max-w-3xl mx-auto">
        <header class="mb-12 border-b border-hairline pb-8">
          <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink mb-4">About Tooltails</h1>
          <p class="text-lg text-mute leading-relaxed">
            We build free, privacy-focused online tools to make your everyday tasks simpler and faster.
          </p>
        </header>

        <div class="space-y-12 text-body leading-relaxed">
          <section>
            <h2 class="text-2xl font-bold tracking-tight text-ink mb-4">Why Tooltails Exists</h2>
            <p class="mb-4">
              The internet is full of utility websites, but many are cluttered with intrusive ads, unnecessary account registrations, and paywalls. Tooltails was created with a simple mission: to provide high-quality, professional-grade tools that respect your time and attention.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-bold tracking-tight text-ink mb-4">Free Tools for Everyday Tasks</h2>
            <p class="mb-4">
              Whether you're a writer needing to check your word count, a student calculating dates, or a professional analyzing text, our tools are designed to streamline your everyday productivity. We focus on utility and efficiency above all else.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-bold tracking-tight text-ink mb-4">Privacy First Approach</h2>
            <p class="mb-4">
              Your data is yours. Unlike many online services that upload your text and inputs to remote servers, Tooltails processes your information locally right in your browser whenever possible. This means your sensitive documents, personal dates, and calculations remain secure and private.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-bold tracking-tight text-ink mb-4">Fast, Simple and Accessible</h2>
            <p class="mb-4">
              Every tool we build adheres to strict design principles: they must load instantly, be completely intuitive to use, and be accessible across all devices. We strip away the bloat so you can get your answers and get back to your work.
            </p>
          </section>

          <section>
            <h2 class="text-2xl font-bold tracking-tight text-ink mb-4">Our Growing Collection of Tools</h2>
            <p class="mb-4">
              Explore our current suite of productivity applications:
            </p>
            <ul class="flex flex-col gap-3 ml-2">
              <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="9 18 15 12 9 6"></polyline></svg>
                <a href="/word-counter" class="text-ink font-medium hover:text-primary transition-colors">Word Counter and Text Analyzer</a>
              </li>
              <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="9 18 15 12 9 6"></polyline></svg>
                <a href="/age-calculator" class="text-ink font-medium hover:text-primary transition-colors">Age Calculator</a>
              </li>
              <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="9 18 15 12 9 6"></polyline></svg>
                <a href="/age-difference" class="text-ink font-medium hover:text-primary transition-colors">Age Difference</a>
              </li>
              <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="9 18 15 12 9 6"></polyline></svg>
                <a href="/birthday-countdown" class="text-ink font-medium hover:text-primary transition-colors">Birthday Countdown</a>
              </li>
              <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><polyline points="9 18 15 12 9 6"></polyline></svg>
                <a href="/duration" class="text-ink font-medium hover:text-primary transition-colors">Date Duration Calculator</a>
              </li>
            </ul>
          </section>
        </div>
      </div>
    </article>

    <div class="mt-16 pt-8 border-t border-hairline bg-canvas-soft">
      <FAQSection items={faqs} />
    </div>
  </main>

  <SiteFooter />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
