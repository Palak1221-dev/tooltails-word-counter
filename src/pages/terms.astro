---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';

const seoTitle = "Terms of Service | Tooltails";
const seoDescription = "Read the Terms of Service for using Tooltails and its collection of free online productivity tools.";
const canonicalUrl = "https://tooltails.com/terms/";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Terms of Service",
  "description": seoDescription,
  "url": canonicalUrl,
  "publisher": {
    "@type": "Organization",
    "name": "Tooltails",
    "url": "https://tooltails.com"
  }
};
---

<Layout title={seoTitle} description={seoDescription} canonical={canonicalUrl}>
  <SiteHeader />
  
  <main class="min-h-screen pt-16 pb-24 px-4 sm:px-6 bg-canvas">
    <div class="max-w-3xl mx-auto">
      <header class="mb-12 border-b border-hairline pb-8">
        <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink mb-4">Terms of Service</h1>
        <p class="text-sm font-medium text-mute tracking-wide uppercase">Last updated: June 2026</p>
      </header>

      <div class="space-y-12 text-body leading-relaxed">
        <section>
          <h2 class="text-2xl font-bold tracking-tight text-ink mb-4">Acceptance of Terms</h2>
          <p class="mb-4">
            By accessing and using Tooltails ("the Service"), you accept and agree to be bound by the terms and provision of this agreement. If you do not agree to abide by these terms, please do not use this Service.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold tracking-tight text-ink mb-4">Permitted Use</h2>
          <p class="mb-4">
            Tooltails provides a collection of free online productivity tools. You are granted a limited, non-exclusive, non-transferable license to use the Service for personal and commercial purposes. You agree not to:
          </p>
          <ul class="list-disc list-inside space-y-2 ml-4">
            <li>Use the Service for any illegal or unauthorized purpose.</li>
            <li>Attempt to hack, destabilize, or disrupt the Service's infrastructure.</li>
            <li>Use automated scripts, bots, or scrapers to access the Service without explicit permission.</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold tracking-tight text-ink mb-4">Disclaimer</h2>
          <p class="mb-4">
            The tools provided by Tooltails (including but not limited to calculations, text analysis, and time estimates) are provided on an "as is" and "as available" basis. While we strive for accuracy, we make no warranties, expressed or implied, regarding the reliability, exactness, or fitness for a particular purpose of the results generated by our tools.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold tracking-tight text-ink mb-4">Limitation of Liability</h2>
          <p class="mb-4">
            In no event shall Tooltails or its operators be liable for any direct, indirect, incidental, consequential, or special damages arising out of or in any way connected with your access to, use of, or inability to use the Service. This includes any loss of data, loss of revenue, or business interruption resulting from the use of our calculations or analysis.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold tracking-tight text-ink mb-4">Third-Party Services</h2>
          <p class="mb-4">
            The Service may contain links to third-party websites or services that are not owned or controlled by Tooltails. We have no control over, and assume no responsibility for, the content, privacy policies, or practices of any third-party web sites or services. We do not warrant the offerings of any of these entities.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold tracking-tight text-ink mb-4">Changes to Terms</h2>
          <p class="mb-4">
            We reserve the right, at our sole discretion, to modify or replace these Terms at any time. If a revision is material, we will try to provide at least 30 days' notice prior to any new terms taking effect. What constitutes a material change will be determined at our sole discretion.
          </p>
        </section>

        <section class="pt-10 mt-10 border-t border-hairline">
          <h2 class="text-2xl font-bold tracking-tight text-ink mb-4">Contact Information</h2>
          <p class="mb-4">
            If you have any questions about these Terms, please contact us at:
          </p>
          <p>
            <a href="mailto:hello@tooltails.com" class="inline-flex text-xl font-bold tracking-tight text-primary hover:text-ink transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-sm">
              hello@tooltails.com
            </a>
          </p>
        </section>
      </div>
    </div>
  </main>

  <SiteFooter />

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
