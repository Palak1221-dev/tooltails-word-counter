---
interface Props {
  title: string;
  description: string;
  badgeText?: string;
}

const { title, description, badgeText } = Astro.props;
---

<header class="relative pt-6 pb-4 px-6 overflow-hidden brand-gradient flex flex-col items-center">
  <div class="max-w-4xl mx-auto text-center relative z-10 flex flex-col items-center">
    {badgeText && (
      <div class="inline-flex items-center gap-2 px-3 py-1 mb-3 text-xs font-bold text-primary bg-primary/10 border border-primary/20 rounded-full shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
        <span class="uppercase tracking-widest">{badgeText}</span>
      </div>
    )}
    <h1 class="text-2xl md:text-4xl lg:text-5xl font-bold tracking-tight text-ink mb-2 leading-[1.1] max-w-4xl" set:html={title} />
    <p class="text-base md:text-lg text-body max-w-3xl leading-relaxed opacity-80 line-clamp-1">
      {description}
    </p>
  </div>
</header>
