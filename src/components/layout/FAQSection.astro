---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  items: FAQItem[];
}

const { title = "Frequently Asked Questions", items } = Astro.props;
---

<section class="px-4 sm:px-6 py-16 md:py-24 bg-canvas-soft border-t border-hairline">
  <div class="max-w-3xl mx-auto">
    <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-12">
      <h2 class="text-2xl font-bold tracking-tight text-ink">{title}</h2>
      <div class="hidden sm:block h-px w-full bg-hairline"></div>
    </div>
    <div class="space-y-3">
      {items.map((item) => (
        <details class="group bg-canvas border border-hairline rounded-3xl overflow-hidden shadow-sm transition-all hover:shadow-md hover:border-primary/20 [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex items-center justify-between px-6 py-4 cursor-pointer hover:bg-canvas-soft transition-colors">
            <span class="text-sm font-bold text-ink tracking-tight">{item.question}</span>
            <div class="w-6 h-6 rounded-full border border-hairline flex items-center justify-center transition-transform group-open:rotate-180 group-hover:bg-canvas">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-mute" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </div>
          </summary>
          <div class="px-6 py-5 text-sm text-body leading-relaxed border-t border-hairline bg-canvas/50">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
