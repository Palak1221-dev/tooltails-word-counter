        <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20 text-primary relative z-10 transition-transform group-hover:scale-110 duration-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
    </div>
  </div>
