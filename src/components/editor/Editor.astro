---
import Toolbar from './Toolbar.astro';
import CleanupPanel from './CleanupPanel.astro';

interface Props {
  placeholder?: string;
}

const { placeholder = "Paste or type your text here to get started..." } = Astro.props;
---

<section class="px-6 pb-4 pt-1">
  <div class="max-w-7xl mx-auto">
    <div class="bg-canvas border border-hairline-strong rounded-[2.5rem] shadow-md overflow-hidden flex flex-col min-h-[550px] transition-all duration-300 focus-within:-translate-y-1 focus-within:shadow-xl focus-within:border-primary focus-within:ring-4 focus-within:ring-primary/20 relative group">
      <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full translate-x-1/3 -translate-y-1/3 blur-3xl group-focus-within:bg-primary/15 transition-colors duration-500 pointer-events-none"></div>
      <div class="relative z-10">
        <Toolbar />
      </div>
      
      <div class="relative z-10">
        <CleanupPanel />
      </div>
      
      <textarea
        id="text-input"
        class="flex-grow w-full p-4 sm:p-8 md:p-12 text-lg sm:text-xl font-medium text-ink focus:outline-none resize-none placeholder:text-mute/40 leading-relaxed bg-transparent relative z-10"
        placeholder={placeholder}
      ></textarea>

      <div class="px-6 py-4 border-t border-hairline bg-canvas flex items-center justify-between text-[11px] font-bold text-mute uppercase tracking-widest relative z-10">
        <span id="editor-status" class="flex items-center gap-2">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
          </span>
          Ready
        </span>
        <div class="flex gap-6">
          <slot name="status-metrics" />
        </div>
      </div>
    </div>
  </div>
</section>
