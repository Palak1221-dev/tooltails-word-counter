---
interface Props {
  readabilityId?: string;
  readingTimeId?: string;
  speakingTimeId?: string;
}

const { 
  readabilityId = "readability-grade", 
  readingTimeId = "reading-time", 
  speakingTimeId = "speaking-time" 
} = Astro.props;
---

<div class="grid md:grid-cols-2 gap-8 mt-8">
  {/* Reading & Speaking Times - Modern Standard Card */}
  <div class="bg-canvas border border-hairline rounded-[2.5rem] p-8 md:p-12 shadow-sm flex flex-col justify-between transition-all hover:shadow-xl group">
    <div>
      <h3 class="text-sm font-bold tracking-tight mb-10 text-ink">Linguistic Pace</h3>
      <div class="space-y-8">
        <div class="flex items-center justify-between">
          <div class="flex flex-col">
            <span class="text-[10px] font-bold text-mute uppercase tracking-widest mb-1">Reading Time</span>
            <span id={readingTimeId} class="text-4xl font-bold tracking-tighter text-ink">0s</span>
          </div>
          <div class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center text-primary group-hover:bg-primary/10 group-hover:scale-110 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
        </div>
        <div class="flex items-center justify-between">
          <div class="flex flex-col">
            <span class="text-[10px] font-bold text-mute uppercase tracking-widest mb-1">Speaking Time</span>
            <span id={speakingTimeId} class="text-4xl font-bold tracking-tighter text-ink">0s</span>
          </div>
          <div class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center text-primary group-hover:bg-primary/10 group-hover:scale-110 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>
          </div>
        </div>
      </div>
    </div>
    <div class="pt-8 border-t border-hairline mt-10">
      <p class="text-[10px] text-mute leading-relaxed font-bold uppercase tracking-widest">
        Standard speeds applied
      </p>
    </div>
  </div>

  {/* Readability Score - Polarity Flipped Card */}
  <div class="bg-primary text-on-primary border border-primary rounded-[2.5rem] p-8 md:p-12 shadow-xl flex flex-col justify-between relative overflow-hidden group hover:shadow-2xl transition-all">
    <div class="absolute top-0 right-0 w-40 h-40 bg-white/10 rounded-full translate-x-1/4 -translate-y-1/4 transition-transform duration-500 group-hover:scale-125 blur-2xl"></div>
    <div class="relative z-10">
      <div class="flex items-center justify-between mb-10">
        <h3 class="text-sm font-bold tracking-tight">Readability Index</h3>
        <span class="text-[10px] font-bold text-on-primary/80 uppercase tracking-widest px-3 py-1 border border-white/20 rounded-full bg-white/5 backdrop-blur-sm shadow-sm">Flesch-Kincaid</span>
      </div>
      <div class="flex items-baseline gap-2 mb-6">
        <span id={readabilityId} class="text-7xl font-bold tracking-tighter">—</span>
        <span class="text-2xl font-bold text-on-primary/50">/ 100</span>
      </div>
      <p id="readability-feedback" class="text-on-primary/90 text-sm font-medium leading-relaxed max-w-[260px]">
        Type more than 5 words to generate a precise readability score.
      </p>
    </div>
    <div class="pt-8 border-t border-white/15 mt-10 relative z-10">
      <div class="flex justify-between items-center text-[10px] font-bold uppercase tracking-widest text-on-primary/70">
        <span>Complexity Level</span>
        <span id="complexity-label" class="text-on-primary font-bold bg-white/10 px-2 py-1 rounded">Awaiting Input</span>
      </div>
    </div>
  </div>
</div>
