---
interface Metric {
  label: string;
  id: string;
  value: string | number;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
---

<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
  {metrics.map((metric) => (
    <div class="bg-canvas p-4 flex flex-col gap-1.5 rounded-[1.5rem] border border-hairline shadow-sm transition-all hover:shadow-md hover:border-primary/30 group">
      <span class="text-[9px] font-bold text-mute uppercase tracking-widest leading-none transition-colors group-hover:text-primary">{metric.label}</span>
      <span id={metric.id} class="text-2xl font-bold tracking-tight text-ink leading-none transition-colors group-hover:text-ink">{metric.value}</span>
    </div>
  ))}
</div>
